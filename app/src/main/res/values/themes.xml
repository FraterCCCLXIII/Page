<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Window-level theme only. The actual UI is themed in Compose
      (see ui/theme/Theme.kt). This exists so the launcher window paints a
      calm background immediately, avoiding any flash on start.

      This is the day (light) variant; values-night/themes.xml supplies the
      dark variant. The background color resolves per night mode via
      @color/page_window_background, so the splash matches the system setting.
    -->
    <style name="Theme.Page" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/page_window_background</item>
        <item name="android:statusBarColor">@color/page_window_background</item>
        <item name="android:navigationBarColor">@color/page_window_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:colorBackground">@color/page_window_background</item>
    </style>
</resources>
